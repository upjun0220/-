def print_yubin_preview(event):
    EVENT_KR = {
        "fall_detected":       "🚨 낙상",
        "electric_shock_risk": "⚡ 감전 위험",
        "pinching":            "⚙️  협착",
        "vibration_anomaly":   "📳 진동이상",
    }
    SEVERITY_KR = {"critical": "즉각 대응", "warning": "주의"}

    label    = EVENT_KR.get(event["event_type"], event["event_type"])
    severity = SEVERITY_KR.get(event["severity"], event["severity"])
    timing   = event["details"]["timing"]

    print("\n" + "="*55)
    print("  ★ 유빈 UI에 표시될 내용 미리보기")
    print("="*55)
    print(f"  사고 유형  : {label}")
    print(f"  심각도     : {severity} ({event['severity']})")
    print(f"  신뢰도     : {event['confidence']:.0%}")
    print(f"  구역       : Zone {event['zone_id']}")
    print(f"  발생 시각  : {timing['event_timestamp']}")
    print(f"  사고 시작  : step {timing['anomaly_start_step']}")
    print(f"  피크 시점  : step {timing['anomaly_peak_step']}")
    print(f"  지속 구간  : {timing['anomaly_duration']} steps ({timing['elapsed_ms']} ms)")
    if event["event_type"] == "fall_detected":
        wp = event["details"].get("worker_pose", {})
        print(f"  작업자 자세: {wp.get('posture')} / 속도 {wp.get('velocity_m_s')} m/s")
    elif event["event_type"] == "electric_shock_risk":
        print(f"  접근 거리  : {event['details'].get('proximity_m')} m")
        print(f"  설비 전압  : {event['details'].get('equipment_voltage_kv')} kV")
    elif event["event_type"] == "pinching":
        print(f"  신체 근접  : {event['details'].get('body_part_proximity_m')} m")
        print(f"  회전수     : {event['details'].get('rotation_rpm')} RPM")
    elif event["event_type"] == "vibration_anomaly":
        print(f"  진동 RMS   : {event['details'].get('rms_vibration_um_s')} μm/s")
        print(f"  이상 주파수: {event['details'].get('frequency_anomaly_hz')} Hz")
    print("="*55)
    print(f"\n  → stage2_event.json 저장 완료 (유빈 파트로 전달)")


# ================================================================
# 그래프
# ================================================================
def plot_result(test_loss, is_anomaly, threshold, timing, clf, scenario):
    detected_en = {
        "fall_detected":       "Fall",
        "electric_shock_risk": "Electric Shock",
        "pinching":            "Pinching",
        "vibration_anomaly":   "Vibration",
    }
    scenario_en = {
        "fall": "Fall", "electric_shock": "Electric Shock",
        "pinching": "Pinching", "vibration": "Vibration",
    }
    input_label    = scenario_en[scenario]
    detected_label = detected_en.get(clf["event_type"], clf["event_type"])

    correct_map = {"fall": "fall_detected", "electric_shock": "electric_shock_risk",
                   "pinching": "pinching", "vibration": "vibration_anomaly"}
    is_correct  = correct_map[scenario] == clf["event_type"]
    tag   = "✓ Correct" if is_correct else "⚠ Misclassified"
    color = "#2C3E50" if is_correct else "#C0392B"

    fig, axes = plt.subplots(1, 2, figsize=(14, 5))
    fig.suptitle(f"Radar-Guard  |  Input: {input_label}  ->  Detected: {detected_label}  {tag}",
                 fontsize=12, fontweight="bold", color=color)

    # Left: Reconstruction error
    ax = axes[0]
    ax.plot(test_loss, color="royalblue", lw=1.5, label="Recon Error (MSE)")
    ax.axhline(threshold, color="red", linestyle="--", lw=1.8,
               label=f"Threshold u+3s = {threshold:.4f}")
    if timing and timing["anomaly_start_step"] is not None:
        ax.axvspan(timing["anomaly_start_step"],
                   timing["anomaly_start_step"] + timing["anomaly_duration"],
                   color="orange", alpha=0.2, label="Accident Window")
        ax.axvline(timing["anomaly_start_step"], color="#F39C12",
                   lw=1.5, linestyle=":", label=f"Start step {timing['anomaly_start_step']}")
        ax.axvline(timing["anomaly_peak_step"], color="red",
                   lw=2, linestyle="-.", label=f"Peak step {timing['anomaly_peak_step']}")
    ax.set_title("(1) Recon Error + Event Timing", fontsize=11, fontweight="bold")
    ax.set_xlabel("Time Step"); ax.set_ylabel("MSE Loss")
    ax.legend(fontsize=8); ax.grid(alpha=0.3)

    # Right: Anomaly points + result summary
    ax = axes[1]
    ax.plot(test_loss, color="gray", alpha=0.4, lw=1)
    anomaly_idx = np.where(is_anomaly)[0]
    ax.scatter(anomaly_idx, test_loss[anomaly_idx],
               color="red", s=40, zorder=5, label=f"Anomaly ({len(anomaly_idx)} pts)")
    ax.axhline(threshold, color="red", linestyle="--", alpha=0.5)

    if timing:
        summary = (f"event_type : {clf['event_type']}\n"
                   f"severity   : {clf['severity']}\n"
                   f"confidence : {clf['confidence']:.0%}\n"
                   f"start_step : {timing['anomaly_start_step']}\n"
                   f"peak_step  : {timing['anomaly_peak_step']}\n"
                   f"duration   : {timing['anomaly_duration']} steps\n"
                   f"elapsed_ms : {timing['elapsed_ms']} ms")
        ax.text(0.02, 0.97, summary, transform=ax.transAxes,
                fontsize=8, va="top", fontfamily="monospace",
                bbox=dict(boxstyle="round,pad=0.4", facecolor="#FFF9C4",
                          edgecolor="#F39C12", alpha=0.9))

    ax.set_title("(2) Anomaly Points + Result Summary", fontsize=11, fontweight="bold")
    ax.set_xlabel("Time Step"); ax.legend(fontsize=8); ax.grid(alpha=0.3)

    plt.tight_layout()
    display(fig)
    fig.savefig(f"result_{scenario}.png", dpi=120, bbox_inches="tight")
    plt.close(fig)
    print(f"[저장] result_{scenario}.png")
    return fig


